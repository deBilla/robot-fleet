{
  "uid": "fleetos-fleet-overview",
  "title": "FleetOS - Fleet Overview",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Total Robots",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "fleetos_robots_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "title": "Active Robots",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "fleetos_robots_active", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "title": "Error Robots",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "fleetos_robots_error", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 4,
      "title": "Avg Battery Level",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "fleetos_avg_battery_level", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "fleetos_websocket_connections", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 6,
      "title": "Active HTTP Connections",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "fleetos_api_active_connections", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" }
    },
    {
      "id": 10,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(fleetos_api_requests_total[1m])) by (method, path)", "legendFormat": "{{method}} {{path}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "title": "API Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(fleetos_api_requests_total[1m])) by (status)", "legendFormat": "HTTP {{status}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "HTTP 5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "HTTP 2.." }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 20,
      "title": "API Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(fleetos_api_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(fleetos_api_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(fleetos_api_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 21,
      "title": "Telemetry Ingestion Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(fleetos_telemetry_packets_total[1m])", "legendFormat": "packets/sec", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "gradientMode": "scheme" },
          "unit": "pps"
        }
      }
    },
    {
      "id": 30,
      "title": "Inference Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(fleetos_inference_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(fleetos_inference_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2 },
          "unit": "s"
        }
      }
    },
    {
      "id": 31,
      "title": "Per-Tenant API Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(fleetos_tenant_api_calls_total[5m])) by (tenant_id)", "legendFormat": "{{tenant_id}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "drawStyle": "bars" },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 40,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "fleetos_kafka_consumer_lag", "legendFormat": "lag", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      }
    },
    {
      "id": 41,
      "title": "HTTP Errors (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(fleetos_api_requests_total{status=~\"4..\"}[5m]))", "legendFormat": "4xx", "refId": "A" },
        { "expr": "sum(rate(fleetos_api_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
